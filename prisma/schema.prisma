generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())

  email     String   @unique
  password  String
  role      String   @default("student")

  name      String?
  studentId String?  @unique
  major     String?
  grade     String?
  bio       String?
  avatar    String?

  createdClubs          Club[]            @relation("ClubCreator")
  clubApplications      ClubApplication[]
  reviewedApplications  ClubApplication[] @relation("ApplicationReviewer")
  clubMemberships       ClubMember[]
  eventSignups          EventSignup[]
  clubComments          ClubComment[]
  createdAnnouncements  Announcement[]    @relation("AnnouncementCreator")
  uploadedGalleryImages ClubGalleryImage[] @relation("GalleryUploader")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Club {
  id          String   @id @default(uuid())

  sourceId    Int?     @unique
  name        String   @unique
  chineseName String?
  englishName String?
  description String?
  purpose     String?
  mission     String?
  category    String?
  logo        String?
  joinInfo    String?
  reviewer    String?
  status      String   @default("active")

  createdById String?
  createdBy   User?    @relation("ClubCreator", fields: [createdById], references: [id], onDelete: SetNull)

  applications  ClubApplication[]
  members       ClubMember[]
  events        Event[]
  announcements Announcement[]
  galleryImages ClubGalleryImage[]
  comments      ClubComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClubApplication {
  id       String @id @default(uuid())

  clubId   String
  userId   String
  reason   String
  status   String @default("pending")

  reviewedById String?
  reviewedAt   DateTime?

  club       Club  @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clubId, userId])
}

model ClubMember {
  id       String @id @default(uuid())

  clubId   String
  userId   String
  role     String @default("member")

  club     Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([clubId, userId])
}

model Event {
  id          String   @id @default(uuid())

  clubId      String
  title       String
  description String?
  location    String?
  startTime   DateTime
  endTime     DateTime
  capacity    Int?
  poster      String?
  status      String   @default("published")

  club        Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  signups     EventSignup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventSignup {
  id       String @id @default(uuid())

  eventId  String
  userId   String
  status   String @default("registered")

  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, userId])
}

model ClubComment {
  id        String   @id @default(uuid())

  clubId    String
  userId    String
  content   String

  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Announcement {
  id          String   @id @default(uuid())

  clubId      String
  createdById String?

  title       String
  content     String
  status      String   @default("published")
  isPinned    Boolean  @default(false)

  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdBy   User?    @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClubGalleryImage {
  id           String   @id @default(uuid())

  clubId       String
  uploadedById String?

  imageUrl     String
  title        String?
  description  String?

  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation("GalleryUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}